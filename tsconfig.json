{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",        // ← change from ESNext
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src"]
}